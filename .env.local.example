# Copy this file to .env.local and fill in real values.
# See SETUP.md for click-by-click instructions on where each value comes from.
# Never commit .env.local — it's already covered by .gitignore.

# ---------------------------------------------------------------------------
# Airtable (data store)
# ---------------------------------------------------------------------------
# Personal access token, created at https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write,
#                  schema.bases:read, schema.bases:write
AIRTABLE_API_KEY=

# The base ID of the Airtable base the 11 tables will live in.
# Found in the base's API docs page (airtable.com/api) or its URL, starts with "app".
AIRTABLE_BASE_ID=

# ---------------------------------------------------------------------------
# Supabase (auth + Postgres)
# ---------------------------------------------------------------------------
# Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings -> API -> service_role key. Server-only, never expose to
# the browser. Used by the Auth Hook and any server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google OAuth (consumed by Supabase Auth, not called directly by the app)
# ---------------------------------------------------------------------------
# From the OAuth client created in Google Cloud Console. These are entered
# into Supabase's Google provider settings, not read directly by Next.js,
# but kept here so the whole credential set lives in one place.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Public form links (JWT-signed, no-login form routes)
# ---------------------------------------------------------------------------
# Any long random string (e.g. `openssl rand -base64 48`). Used to sign and
# verify the tokens in /forms/work-trial, /forms/referee, /forms/arrival,
# /forms/scoring links sent to candidates/referees/hiring managers.
PUBLIC_FORM_JWT_SECRET=

# ---------------------------------------------------------------------------
# Africa's Talking (SMS — used by the Make.com automations, not the app
# itself). Leave blank until the Make scenarios are built.
# ---------------------------------------------------------------------------
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
